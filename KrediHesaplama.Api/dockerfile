FROM ://microsoft.com AS build
WORKDIR /src

# api klasöründeki her şeyi Docker içine kopyalar
COPY . . 

RUN dotnet restore
RUN dotnet publish -c Release -o /app

FROM ://microsoft.com AS final
WORKDIR /app
COPY --from=build /app .
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "KrediHesaplama.Api.dll"]

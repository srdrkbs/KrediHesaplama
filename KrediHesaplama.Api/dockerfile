FROM ://microsoft.com AS build
WORKDIR /src

# Render artık doğrudan bu klasörde olduğu için her şeyi içeri kopyalıyoruz
COPY . .

RUN dotnet restore "KrediHesaplama.Api.csproj"
RUN dotnet publish "KrediHesaplama.Api.csproj" -c Release -o /app

FROM ://microsoft.com AS final
WORKDIR /app
COPY --from=build /app .
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "KrediHesaplama.Api.dll"]

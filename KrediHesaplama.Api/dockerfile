# 1. Aşama: Build (SDK)
FROM mcr.microsoft.com/dotnet/sdk:10.0-alpine AS build
WORKDIR /src

COPY . .
COPY . .

RUN dotnet restore "KrediHesaplama.Api.csproj"
RUN dotnet publish "KrediHesaplama.Api.csproj" -c Release -o /app
RUN dotnet restore "KrediHesaplama.Api.csproj"
RUN dotnet publish "KrediHesaplama.Api.csproj" -c Release -o /app

# 2. Aşama: Final (Runtime)
FROM mcr.microsoft.com/dotnet/aspnet:10.0-alpine AS final
WORKDIR /app

# Alpine üzerinde tarih, saat ve para birimi (Kredi Hesaplama) formatlamaları 
# için gerekli olan dil/kültür kütüphanesini (ICU) ekliyoruz.
RUN apk add --no-cache icu-libs
ENV DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=false

COPY --from=build /app .

ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080

ENTRYPOINT ["dotnet", "KrediHesaplama.Api.dll"]